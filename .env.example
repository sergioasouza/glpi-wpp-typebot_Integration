####################################################################
#  VARIÁVEIS DE AMBIENTE — Copie este arquivo para .env
#  Gere as senhas com: openssl rand -hex 32
#  NUNCA commite o arquivo .env — apenas o .env.example
####################################################################

# ═══════════════════════════════════════════════════════════════
#  SENHA DO BANCO (gere com: openssl rand -hex 32)
# ═══════════════════════════════════════════════════════════════
POSTGRES_TYPEBOT_PASSWORD=TROCAR_gere_com_openssl_rand_hex_32

# ═══════════════════════════════════════════════════════════════
#  DOMÍNIOS — Substitua pelo seu domínio real
# ═══════════════════════════════════════════════════════════════
DOMAIN=seudominio.com.br

# ═══════════════════════════════════════════════════════════════
#  EVOLUTION API (WhatsApp — self-hosted, integração nativa Typebot)
# ═══════════════════════════════════════════════════════════════
POSTGRES_EVOLUTION_PASSWORD=TROCAR_gere_com_openssl_rand_hex_32
AUTHENTICATION_API_KEY=TROCAR_gere_com_openssl_rand_hex_32
EVOLUTION_INSTANCE_NAME=glpi-bot

# Números dos gestores para receber leads comerciais via WhatsApp
# Formato: DDI+DDD+Número, separados por vírgula (sem espaços)
MANAGER_PHONES=5511999999999,5511888888888

# ═══════════════════════════════════════════════════════════════
#  TYPEBOT
# ═══════════════════════════════════════════════════════════════
NEXTAUTH_URL=https://typebot.seudominio.com.br
NEXT_PUBLIC_VIEWER_URL=https://bot.seudominio.com.br
NEXTAUTH_SECRET=TROCAR_gere_com_openssl_rand_hex_32
ENCRYPTION_SECRET=TROCAR_gere_com_openssl_rand_hex_32
ADMIN_EMAIL=admin@seudominio.com.br

# SMTP (opcional — para convites e login por email)
# SMTP_HOST=smtp.seudominio.com.br
# SMTP_PORT=587
# SMTP_USERNAME=noreply@seudominio.com.br
# SMTP_PASSWORD=SUA_SENHA_SMTP
# SMTP_SECURE=false
# NEXT_PUBLIC_SMTP_FROM=Typebot <noreply@seudominio.com.br>

# ═══════════════════════════════════════════════════════════════
#  GLPI PROXY
# ═══════════════════════════════════════════════════════════════

# URL da API REST do GLPI — acessada de DENTRO do container
# Apache continua na porta 80 (não foi movido — sem Nginx!)
GLPI_API_URL=http://host.docker.internal:80/glpi/apirest.php

# Tokens do GLPI (criar em: GLPI > Configurar > Geral > API)
GLPI_APP_TOKEN=TROCAR_copie_do_painel_glpi
GLPI_USER_TOKEN=TROCAR_copie_do_perfil_do_usuario_glpi

# Segredo interno do proxy (gere com: openssl rand -hex 32)
PROXY_SECRET=TROCAR_gere_com_openssl_rand_hex_32
